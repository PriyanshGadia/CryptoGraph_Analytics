# Backend Environment Variables
# Copy this file to .env and fill in your values
# Get Supabase credentials from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Get Groq API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get LangChain API key from: https://smith.langchain.com
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=stgcn-crypto

# Get Sentry DSN from: https://sentry.io
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

MODEL_ARTIFACT_PATH=./artifacts/best_model.pt
ENVIRONMENT=development
