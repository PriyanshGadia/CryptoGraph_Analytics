# ML Pipeline Environment Variables
# Copy this file to .env and fill in your values

# Supabase (same as backend)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Binance API - get from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

# FRED API - get free key from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Weights & Biases - get from: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# Sentry (same as backend)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# These are free public APIs — no key needed
FEAR_GREED_URL=https://api.alternative.me/fng/?limit=1000
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
